# Model Provider: openrouter | claude | ollama
MODEL_PROVIDER=openrouter

# OpenRouter (recommended — supports 10+ models)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=

# Ollama (optional, local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Tool API Keys (all optional — agent degrades gracefully without them)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
NVD_API_KEY=

# Cache directory
CACHE_DIR=.cache
